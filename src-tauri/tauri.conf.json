{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Torch App Template",
  "version": "0.1.0",
  "identifier": "com.torch.template",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Torch App Template",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdn.statically.io; font-src 'self' data: https://cdn.jsdelivr.net https://cdn.statically.io; img-src 'self' data: https: blob:; connect-src 'self' http://localhost:* ws://localhost:* wss://* https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../dist/": "frontend/dist/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
