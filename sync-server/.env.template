# Sync server environment variables.
# Copy to `.env` and fill in. NEVER commit `.env`.

# --- Server -------------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=3161
LOG_LEVEL=info

# --- Database (Postgres via Prisma) ------------------------------------------
# Required in production. When unset, the server falls back to the in-memory
# store (test/dev only — phase-09 §3 Sync Server).
#
# PRODUCTION (docker-compose.prod.yaml): set POSTGRES_PASSWORD to a strong
# value and reference it in DATABASE_URL with host `sync-db` (the compose
# service name) on the INTERNAL port 5432. The prod compose binds Postgres to
# localhost only -- it is never reachable from the internet.
#   POSTGRES_PASSWORD=<strong-random>
#   DATABASE_URL=postgresql://postgres:<strong-random>@sync-db:5432/idc_sync
#
# LOCAL DEV (docker-compose.yaml): the dev default below talks to the published
# 5449 port from the host.
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5449/idc_sync

# --- Redis (cache + BullMQ) --------------------------------------------------
# Optional in v0.1.0. When unset, /healthz reports redis: "ok" (n/a).
REDIS_URL=

# --- Auth (RS256 in production) ----------------------------------------------
# Production requires BOTH keys (PEM-encoded RSA): the server SIGNS tokens with
# the private key and VERIFIES with the public key; the desktop app verifies
# offline with the public key. Generate with:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Paste the full PEM (including BEGIN/END lines). In docker-compose, prefer
# JWT_PUBLIC_KEY_FILE / JWT_PRIVATE_KEY_FILE-style mounting, or keep the PEM in
# this .env (loaded via env_file) -- multi-line PEMs are fine in an env_file.
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
# Non-production HS256 fallback. Must be 32+ chars. NEVER use in production.
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- First-launch bootstrap (phase-02 §7.21) ---------------------------------
BOOTSTRAP_SUPERADMIN_EMAIL=
BOOTSTRAP_SUPERADMIN_PASSWORD=
BOOTSTRAP_TENANT_ID=
DEFAULT_ENTITY_ID=

# --- Sync limits -------------------------------------------------------------
SYNC_PUSH_BATCH_LIMIT=50
SYNC_PULL_BATCH_LIMIT=200
SYNC_RETENTION_DAYS=30

# --- Inter-service auth (future) ---------------------------------------------
SERVICE_API_KEY=

# --- Prometheus metrics (phase-08 §7.17) ------------------------------------
# Unset = /metrics endpoint 404s.
METRICS_TOKEN=

# --- CORS --------------------------------------------------------------------
# The Tauri webview origin (tauri://localhost, http://tauri.localhost) and
# localhost dev origins are ALWAYS allowed. This var adds EXTRA origins
# (comma-separated) -- e.g. a staging web client. Leave empty for the desktop
# app alone. (Read by src/app/plugins/cors.ts as CORS_EXTRA_ORIGINS.)
CORS_EXTRA_ORIGINS=
