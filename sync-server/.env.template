# Sync server environment variables.
# Copy to `.env` and fill in. NEVER commit `.env`.

# --- Server -------------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# --- Database (Postgres via Prisma) ------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/idc_sync

# --- Redis (cache + BullMQ) --------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Auth (RS256 JWT) --------------------------------------------------------
JWT_PUBLIC_KEY_PATH=./keys/jwt.pub.pem
JWT_PRIVATE_KEY_PATH=./keys/jwt.pem
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Sync --------------------------------------------------------------------
SYNC_PUSH_BATCH_LIMIT=50
SYNC_PULL_BATCH_LIMIT=200
SYNC_RETENTION_DAYS=30

# --- Inter-service auth (future) ---------------------------------------------
SERVICE_API_KEY=

# --- CORS --------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=tauri://localhost,http://localhost:1420
